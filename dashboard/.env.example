# Ataraxia Dashboard Configuration
# Copy this file to .env and adjust values as needed

# --- Environment Mode ---
# Options: development (default), production
NODE_ENV=development

# --- Server Ports ---
# Main dashboard server port
PORT=4173

# System stats API server port
STATS_PORT=4175

# --- Home Assistant Integration ---
# Home Assistant instance URL
VITE_HA_URL=http://192.168.1.91:8123

# Home Assistant API token (long-lived access token)
# Generate at: Home Assistant → Settings → Devices & Services → Developer Tools → Long-Lived Access Tokens
VITE_HA_TOKEN=your_token_here

# Stats API URL (used by frontend)
VITE_STATS_URL=http://192.168.1.91:4175

# Optional: Override HA_URL/HA_TOKEN for server-side use (if different from VITE_* vars)
# HA_URL=http://192.168.1.91:8123
# HA_TOKEN=your_token_here

# --- Dashboard Authentication ---
# Bearer token for protecting the dashboard (required in production)
# Generate with: openssl rand -hex 32
DASHBOARD_TOKEN=your_token_here

# --- Telegram Notifications (Optional) ---
# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (get from @userinfobot or /getUpdates API)
TELEGRAM_CHAT_ID=

# --- Circuit Breaker Configuration ---
# Number of failures before opening circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3

# Time (ms) to wait before attempting recovery
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# --- Rate Limiter Configuration ---
# Maximum requests per window
RATE_LIMIT_REQUESTS=10

# Time window (ms) for rate limiting (default: 1 minute)
RATE_LIMIT_WINDOW=60000

# --- Logging Configuration ---
# Log level for development environment (debug, info, warn, error)
LOG_LEVEL_DEV=debug

# Log level for production environment (info, warn, error)
LOG_LEVEL_PROD=info

# Log file rotation: max file size before rotation (e.g., 20m for 20MB)
LOG_FILE_MAX_SIZE=20m

# Log file retention: number of days to keep log files
LOG_FILE_MAX_DAYS=14

# --- Request Logging ---
# Maximum number of requests to keep in memory
MAX_REQUEST_LOGS=1000

# Response time threshold (ms) for marking as slow query
SLOW_QUERY_THRESHOLD=500

# Maximum number of slow queries to keep in memory
MAX_SLOW_QUERIES=100

# --- Health Check & History ---
# Maximum history records to keep (default: 288 = 24h @ 5min intervals)
HISTORY_MAX_RECORDS=288

# Consecutive failures threshold before marking unhealthy
HEALTH_CHECK_FAIL_THRESHOLD=3

# Maximum notifications to keep in memory
NOTIFICATIONS_MAX=50

# --- Stats Recording ---
# Interval (ms) for recording system stats (default: 300000 = 5 minutes)
STATS_HISTORY_INTERVAL=300000

# Maximum stats history records to keep (default: 288 = 24h @ 5min intervals)
MAX_STATS_HISTORY_RECORDS=288
